<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chess Room</title>
    <link rel="stylesheet" href="./css/style.css">
</head>

<style>
    
    :root {
        color-scheme: dark;
        --bg: #101417;
        --panel: #171d21;
        --panel-soft: #20282d;
        --text: #f7f3ea;
        --muted: #aab3b7;
        --light-square: #ead7b8;
        --dark-square: #76916b;
        --accent: #e0b450;
    }

    * {
        box-sizing: border-box;
    }

    body {
        min-height: 100vh;
        margin: 0;
        background:
            radial-gradient(circle at 20% 10%, rgba(224, 180, 80, 0.12), transparent 28rem),
            linear-gradient(135deg, #0f1416, #182024 55%, #121719);
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .app-shell {
        min-height: 100vh;
        display: grid;
        grid-template-columns: minmax(17rem, 22rem) minmax(20rem, 42rem);
        align-items: center;
        justify-content: center;
        gap: 2rem;
        padding: 2rem;
    }

    .sidebar {
        width: 100%;
        padding: 1.25rem;
        background: color-mix(in srgb, var(--panel) 92%, transparent);
        border: 1px solid rgba(255, 255, 255, 0.09);
        border-radius: 8px;
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.28);
    }

    .eyebrow {
        margin: 0 0 0.35rem;
        color: var(--accent);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3.4rem);
        line-height: 1;
        letter-spacing: 0;
    }

    .status {
        min-height: 3rem;
        margin: 1rem 0 1.25rem;
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.5;
    }

    .stats {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
    }

    .stat {
        min-width: 0;
        padding: 0.8rem;
        border-radius: 8px;
        background: var(--panel-soft);
        border: 1px solid rgba(255, 255, 255, 0.07);
    }

    .stat-label {
        display: block;
        margin-bottom: 0.25rem;
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .stat-value {
        display: block;
        min-height: 1.6rem;
        overflow-wrap: anywhere;
        font-size: 1.1rem;
        font-weight: 800;
    }

    .captured {
        font-family: "Segoe UI Symbol", "Apple Color Emoji", sans-serif;
        font-size: 1.25rem;
        letter-spacing: 0;
    }

    .reset-button {
        width: 100%;
        min-height: 2.75rem;
        margin-top: 1rem;
        border: 0;
        border-radius: 8px;
        background: var(--accent);
        color: #1d1707;
        font-weight: 800;
        cursor: pointer;
    }

    .board-wrap {
        width: min(92vw, 42rem);
        aspect-ratio: 1;
        padding: clamp(0.45rem, 1.6vw, 0.75rem);
        border-radius: 8px;
        background: #242015;
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.45);
    }

    .chessboard {
        display: grid;
        grid-template-columns: repeat(8, minmax(0, 1fr));
        grid-template-rows: repeat(8, minmax(0, 1fr));
        width: 100%;
        height: 100%;
        overflow: hidden;
        border-radius: 6px;
        transform: rotate(0deg);
        transition: transform 180ms ease;
    }

    .piece.white {
        color: #fff7e5;
        filter: drop-shadow(0 2px 2px rgba(0, 0, 0, 0.85));
    }

    .piece.black {
        color: #171615;
        filter: drop-shadow(0 1px 1px rgba(255, 255, 255, 0.35));
    }

    .flipped {
        transform: rotate(180deg);
    }

    .square {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 0;
        padding: 0;
        user-select: none;
    }

    .square.light {
        background-color: var(--light-square);
    }

    .square.dark {
        background-color: var(--dark-square);
    }

    .square.last-move {
        box-shadow: inset 0 0 0 999px rgba(224, 180, 80, 0.28);
    }

    .square.selected {
        box-shadow: inset 0 0 0 4px rgba(255, 247, 229, 0.72);
    }

    .square.move-target::after,
    .square.capture-target::after {
        content: "";
        position: absolute;
        width: 28%;
        aspect-ratio: 1;
        border-radius: 999px;
        background: rgba(20, 20, 20, 0.25);
    }

    .square.capture-target::after {
        width: 78%;
        border: 0.35rem solid rgba(120, 20, 20, 0.35);
        background: transparent;
    }

    .piece {
        position: relative;
        z-index: 1;
        width: 100%;
        height: 100%;
        display: grid;
        place-items: center;
        font-family: "Segoe UI Symbol", "Apple Color Emoji", sans-serif;
        font-size: clamp(2.1rem, 8vw, 4.6rem);
        line-height: 1;
        cursor: default;
        touch-action: none;
    }

    .piece.draggable {
        cursor: grab;
    }

    .piece.draggable:active {
        cursor: grabbing;
    }

    .dragging {
        opacity: 0.5;
    }

    .flipped .piece {
        transform: rotate(180deg);
    }

    .promotion-dialog {
        position: fixed;
        inset: 0;
        z-index: 10;
        display: grid;
        place-items: center;
        padding: 1rem;
        background: rgba(6, 8, 9, 0.62);
    }

    .promotion-dialog.hidden {
        display: none;
    }

    .promotion-panel {
        width: min(22rem, 92vw);
        padding: 1rem;
        border-radius: 8px;
        background: var(--panel);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
    }

    .promotion-title {
        margin: 0 0 0.75rem;
        font-weight: 800;
    }

    .promotion-choices {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.5rem;
    }

    .promotion-choice {
        min-height: 4rem;
        border: 0;
        border-radius: 8px;
        background: var(--panel-soft);
        color: var(--text);
        font-family: "Segoe UI Symbol", "Apple Color Emoji", sans-serif;
        font-size: 2.4rem;
        cursor: pointer;
    }

    .shake {
        animation: shake 220ms linear;
    }

    @keyframes shake {
        0%, 100% {
            transform: translateX(0) rotate(var(--board-rotation, 0deg));
        }

        25% {
            transform: translateX(-0.35rem) rotate(var(--board-rotation, 0deg));
        }

        75% {
            transform: translateX(0.35rem) rotate(var(--board-rotation, 0deg));
        }
    }

    .chessboard.flipped {
        --board-rotation: 180deg;
    }

    @media (max-width: 820px) {
        .app-shell {
            grid-template-columns: 1fr;
            align-content: center;
            gap: 1rem;
            padding: 1rem;
        }

        .sidebar {
            order: 2;
        }

        .board-wrap {
            width: min(94vw, 34rem);
            justify-self: center;
        }

        .stats {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }
    }

    @media (max-width: 540px) {
        .stats {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .piece {
            font-size: clamp(2rem, 11vw, 3.5rem);
        }
    }
</style>


<body>
    <div class="app-shell">
        <aside class="sidebar">
            <p class="eyebrow">Live match</p>
            <h1>Chess Room</h1>
            <p class="status" data-status>White to move.</p>
            <div class="stats">
                <div class="stat">
                    <span class="stat-label">You</span>
                    <span class="stat-value" data-role>Spectator</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Turn</span>
                    <span class="stat-value" data-turn>White</span>
                </div>
                <div class="stat">
                    <span class="stat-label">White lost</span>
                    <span class="stat-value captured" data-captured-white></span>
                </div>
                <div class="stat">
                    <span class="stat-label">Black lost</span>
                    <span class="stat-value captured" data-captured-black></span>
                </div>
            </div>
            <button class="reset-button" type="button" data-reset>New game</button>
        </aside>

        <main class="board-wrap" aria-label="Chess board">
            <div class="chessboard"></div>
        </main>
    </div>

    <div class="promotion-dialog hidden" data-promotion-dialog>
        <div class="promotion-panel" role="dialog" aria-modal="true" aria-label="Choose promotion piece">
            <p class="promotion-title">Promote pawn</p>
            <div class="promotion-choices" data-promotion-choices></div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js"></script>
    <script src="/js/chessgame.js"></script>
</body>

</html>
